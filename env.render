# =============================================================================
# Render.com → Web Service → Environment
# Add each line as KEY = VALUE (skip comment lines starting with #).
# LLM keys are optional: leave blank to search Portal with the user's text as-is.
# =============================================================================

# Required: ArcGIS Portal Sharing REST root (no trailing slash)
PORTAL_SHARING_REST=https://geoportal.nead.nebraska.edu/portal/sharing/rest

PORTAL_GROUP_ID=cdfaf0b822344c7792b688998094b1f0

# Optional: only if you need to search secured/private items (server-side token)
PORTAL_TOKEN=

# LLM: auto = Gemini if key set, else Hugging Face, else plain search (no API keys required)
LLM_PROVIDER=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional Hugging Face token for higher-rate-limit access to the public inference fallback.
# You can set either HUGGINGFACE_API_KEY or HF_TOKEN in the Render dashboard.
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=google/gemma-2-2b-it
HUGGINGFACE_ROUTER_URL=https://router.huggingface.co/v1

# Browsers allowed to call this API (comma-separated, no spaces around commas).
# GitHub Pages for this repo uses origin https://wenjiewangwwj.github.io
# Add more origins separated by commas if needed (e.g. a custom domain).
CORS_ORIGINS=https://wenjiewangwwj.github.io,http://127.0.0.1:5500,http://localhost:5500

# --- Only if you switch LLM_PROVIDER to openai_compatible (e.g. Groq) ---
# OPENAI_COMPAT_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_COMPAT_API_KEY=
# OPENAI_COMPAT_MODEL=llama-3.3-70b-versatile

# --- Only if you switch LLM_PROVIDER to ollama (not typical on Render) ---
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2

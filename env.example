# Copy to .env and edit.

# --- ArcGIS Portal (required) ---
# From your portal URL https://geoportal.nead.nebraska.edu/portal/home/index.html
# the Sharing REST root is almost always:
#   https://geoportal.nead.nebraska.edu/portal/sharing/rest
# (no trailing slash)
PORTAL_SHARING_REST=https://geoportal.nead.nebraska.edu/portal/sharing/rest

# Optional: restrict catalog search to items shared with this Portal group (ArcGIS q: group:<id>).
# Leave empty to search the entire portal catalog.
PORTAL_GROUP_ID=cdfaf0b822344c7792b688998094b1f0

# Optional: Portal OAuth2 token for private items (see ArcGIS REST docs: /sharing/rest/oauth2/token)
# Leave empty for anonymous search (public items only).
PORTAL_TOKEN=

# --- LLM (optional expansion before Portal search) ---
# auto = try Gemini if GEMINI_API_KEY set, else Hugging Face router, else search with your text as-is (no error).
# none = never call an LLM. gemini | huggingface | hf | ollama | openai_compatible = force that provider (with fallback).
# Gemini: https://ai.google.dev/gemini-api/docs — key: https://aistudio.google.com/apikey
LLM_PROVIDER=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Hugging Face Router (OpenAI-compatible). Optional free read token improves success rate:
# https://huggingface.co/docs/huggingface_hub/quick-start#authentication
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=meta-llama/Llama-3.2-1B-Instruct
HUGGINGFACE_ROUTER_URL=https://router.huggingface.co/v1

# --- Optional: local Ollama ---
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2

# --- Optional: OpenAI-compatible free tier (e.g. Groq — sign up for a free API key) ---
# LLM_PROVIDER=openai_compatible
# OPENAI_COMPAT_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_COMPAT_API_KEY=
# OPENAI_COMPAT_MODEL=llama-3.3-70b-versatile

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated origins for CORS. For GitHub Pages add your site origin, e.g.:
# https://yourgithubusername.github.io
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8000
